# Castflow — full Docker install
# Setup: make install  (copies this file to .env)

# ─── Public URLs (what end users / browsers see) ───────────────────────────────
# Change CASTFLOW_PUBLIC_HOST for production (e.g. api.example.com)
CASTFLOW_PUBLIC_SCHEME=http
CASTFLOW_PUBLIC_HOST=localhost
CASTFLOW_API_PORT=8080

CASTFLOW_API_BASE_URL=http://localhost:8080
CASTFLOW_CDN_BASE_URL=http://localhost:8080/media
CASTFLOW_PLAYER_BASE_URL=http://localhost:8080/player

# Production example:
# CASTFLOW_PUBLIC_SCHEME=https
# CASTFLOW_PUBLIC_HOST=api.example.com
# CASTFLOW_API_PORT=443
# CASTFLOW_API_BASE_URL=https://api.example.com
# CASTFLOW_CDN_BASE_URL=https://cdn.example.com
# CASTFLOW_PLAYER_BASE_URL=https://player.example.com

# ─── Infra ports on host ─────────────────────────────────────────────────────
CASTFLOW_POSTGRES_PORT=5433
CASTFLOW_REDIS_PORT=6380
CASTFLOW_ASYNQMON_PORT=3000
CASTFLOW_RUSTFS_PORT=9000
CASTFLOW_RUSTFS_CONSOLE_PORT=9001

CASTFLOW_ASYNQMON_URL=http://localhost:3000
CASTFLOW_RUSTFS_URL=http://localhost:9000
CASTFLOW_RUSTFS_CONSOLE_URL=http://localhost:9001

# ─── App ─────────────────────────────────────────────────────────────────────
CASTFLOW_HTTP_ADDR=:8080
CASTFLOW_API_KEY=dev-secret-key
CASTFLOW_LOG_LEVEL=info

# Container → container (Docker network service names)
CASTFLOW_DATABASE_URL=postgres://castflow:castflow@postgres:5432/castflow?sslmode=disable
CASTFLOW_REDIS_URL=redis://redis:6379/0

CASTFLOW_STORAGE_DRIVER=local
CASTFLOW_STORAGE_LOCAL_DIR=/app/data/storage

# Optional: RustFS S3 inside Docker network
# CASTFLOW_STORAGE_DRIVER=s3
# CASTFLOW_S3_ENDPOINT=rustfs:9000
# CASTFLOW_S3_BUCKET=castflow-vod
# CASTFLOW_S3_REGION=us-east-1
# CASTFLOW_S3_ACCESS_KEY=minioadmin
# CASTFLOW_S3_SECRET_KEY=minioadmin
# CASTFLOW_S3_USE_SSL=false

CASTFLOW_FFMPEG_PATH=ffmpeg
CASTFLOW_FFPROBE_PATH=ffprobe
CASTFLOW_QUALITIES=360p,720p,1080p
CASTFLOW_HLS_SEGMENT_SECONDS=6
CASTFLOW_THUMBNAIL_AT_SEC=1
CASTFLOW_TOOLTIP_INTERVAL_SEC=5
CASTFLOW_TEMP_DIR=/app/data/tmp

CASTFLOW_WORKER_CONCURRENCY=2
CASTFLOW_ENABLE_EMBEDDED_WORKER=false

CASTFLOW_OUTBOX_POLL_MS=1000
CASTFLOW_OUTBOX_BATCH_SIZE=50
