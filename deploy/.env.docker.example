# Castflow — Docker (make install)
# Postgres/Redis wiring is in docker-compose — don't set them here.

# ─── Public URLs ───────────────────────────────────────────────────────────────
# Dev: one base URL via nginx on port 80 (CDN=/media, Player=/player auto-derived)
CASTFLOW_BASE_URL=http://localhost

# Production — single domain with HTTPS (after: make ssl-certbot DOMAIN=example.com)
# CASTFLOW_BASE_URL=https://example.com

# Production — separate domains (uncomment if needed):
# CASTFLOW_API_BASE_URL=https://api.example.com
# CASTFLOW_CDN_BASE_URL=https://cdn.example.com
# CASTFLOW_PLAYER_BASE_URL=https://player.example.com

# ─── App ─────────────────────────────────────────────────────────────────────
CASTFLOW_API_KEY=dev-secret-key
CASTFLOW_LOG_LEVEL=info
# CASTFLOW_LOG_LEVEL=debug   # verbose logs — then: make docker-restart

CASTFLOW_STORAGE_DRIVER=local
CASTFLOW_STORAGE_LOCAL_DIR=/app/data/storage

# Optional: RustFS S3 (service name inside Docker network)
# CASTFLOW_STORAGE_DRIVER=s3
# CASTFLOW_S3_ENDPOINT=rustfs:9000
# CASTFLOW_S3_BUCKET=castflow-vod
# CASTFLOW_S3_REGION=us-east-1
# CASTFLOW_S3_ACCESS_KEY=minioadmin
# CASTFLOW_S3_SECRET_KEY=minioadmin
# CASTFLOW_S3_USE_SSL=false

CASTFLOW_FFMPEG_PATH=ffmpeg
CASTFLOW_FFPROBE_PATH=ffprobe
CASTFLOW_QUALITIES=360p,720p,1080p
# Qualities shown in the player menu (subset of transcoded; default = all CASTFLOW_QUALITIES)
# CASTFLOW_PLAYER_QUALITIES=720p,1080p
CASTFLOW_HLS_SEGMENT_SECONDS=6
CASTFLOW_THUMBNAIL_AT_SEC=1
CASTFLOW_TOOLTIP_INTERVAL_SEC=5
CASTFLOW_TOOLTIP_MAX_FRAMES=60
CASTFLOW_TOOLTIP_COLS=10
CASTFLOW_TEMP_DIR=/app/data/tmp

CASTFLOW_WORKER_CONCURRENCY=2
# API container also consumes the queue (docker-compose overrides to true)
CASTFLOW_ENABLE_EMBEDDED_WORKER=true

CASTFLOW_OUTBOX_POLL_MS=1000
CASTFLOW_OUTBOX_BATCH_SIZE=50
