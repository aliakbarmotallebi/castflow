# Castflow — local development (without Docker app container)
# For full Docker install use: make install

CASTFLOW_HTTP_ADDR=:8080
CASTFLOW_API_KEY=dev-secret-key
CASTFLOW_LOG_LEVEL=info

CASTFLOW_CDN_BASE_URL=http://localhost:8080/media
CASTFLOW_PLAYER_BASE_URL=http://localhost:8080/player
CASTFLOW_API_BASE_URL=http://localhost:8080

# Matches ports exposed by `make docker-deps` (deploy/docker-compose.yml)
CASTFLOW_DATABASE_URL=postgres://castflow:castflow@localhost:5433/castflow?sslmode=disable
# Redis is the Asynq backend (queue UI: http://localhost:3000)
CASTFLOW_REDIS_URL=redis://localhost:6380/0

CASTFLOW_STORAGE_DRIVER=local
CASTFLOW_STORAGE_LOCAL_DIR=./data/storage

# Optional: RustFS S3 (started by `make docker-deps`, not used until driver=s3)
# CASTFLOW_STORAGE_DRIVER=s3
CASTFLOW_S3_ENDPOINT=localhost:9000
CASTFLOW_S3_BUCKET=castflow-vod
CASTFLOW_S3_REGION=us-east-1
CASTFLOW_S3_ACCESS_KEY=minioadmin
CASTFLOW_S3_SECRET_KEY=minioadmin
CASTFLOW_S3_USE_SSL=false

CASTFLOW_FFMPEG_PATH=ffmpeg
CASTFLOW_FFPROBE_PATH=ffprobe
CASTFLOW_QUALITIES=360p,720p,1080p
CASTFLOW_HLS_SEGMENT_SECONDS=6
CASTFLOW_THUMBNAIL_AT_SEC=1
CASTFLOW_TOOLTIP_INTERVAL_SEC=5
CASTFLOW_TEMP_DIR=./data/tmp

CASTFLOW_WORKER_CONCURRENCY=2
# true = worker inside API process (local dev default)
# false = use `make run-worker` or Docker `castflow-worker` service
CASTFLOW_ENABLE_EMBEDDED_WORKER=true

# Transactional outbox relay (polls Postgres, enqueues to Asynq)
CASTFLOW_OUTBOX_POLL_MS=1000
CASTFLOW_OUTBOX_BATCH_SIZE=50
